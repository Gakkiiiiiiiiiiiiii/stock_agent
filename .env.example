DATABASE_URL=postgresql://agent:agent_pass@localhost:5432/financial_agent
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
REDIS_URL=redis://localhost:6379/0
RERANKER_URL=http://localhost:8010
AGENT_MODEL_PROVIDER=deepseek
AGENT_MODEL_NAME=deepseek-v4-pro
AGENT_MODEL_BASE_URL=https://api.deepseek.com
AGENT_MODEL_API_KEY=your_deepseek_key
QMT_BRIDGE_PYTHON=../quant/.venv-qmt36/Scripts/python.exe
QMT_BRIDGE_SCRIPT=../quant/scripts/qmt_bridge.py
QMT_INSTALL_DIR=../quant/runtime/qmt_client/installed
QMT_USERDATA_DIR=../quant/runtime/qmt_client/installed/userdata_mini
QMT_ACCOUNT_ID=
NEWS_DATA_PROVIDER=local
LOG_LEVEL=INFO
ANALYSIS_MODEL_PROVIDER=deepseek
ANALYSIS_MODEL_NAME=deepseek-v4-pro
ANALYSIS_MODEL_BASE_URL=https://api.deepseek.com
ANALYSIS_MODEL_API_KEY=your_deepseek_key
# 视觉模型必须是支持 image_url 图片输入的多模态模型（如 qwen-vl-max / glm-4v / gpt-4o）。
# 配置为纯文本模型时视觉环节会自动降级为 OCR 文本复核，并在日志中告警。
VISUAL_MODEL_PROVIDER=deepseek
VISUAL_MODEL_NAME=deepseek-v4-pro
VISUAL_MODEL_BASE_URL=https://api.deepseek.com
VISUAL_MODEL_API_KEY=your_deepseek_key
# 部分模型（如 kimi k3）只允许 temperature=1，按需调整
VISUAL_MODEL_TEMPERATURE=0.1
EMBEDDING_MODEL=deterministic-local
RERANKER_MODEL=local-lexical-reranker
CONTENT_STORAGE_DIR=storage/content
BILIBILI_COOKIE_FILE=storage/runtime/bilibili.cookies.txt
BILIBILI_COOKIE_HEADER=
BILIBILI_COOKIES_FROM_BROWSER=
BILIBILI_COOKIES_BROWSER_PROFILE=
ASR_PROVIDER=faster_whisper
# 中文财经口播建议 medium 或 large-v3（GPU）；Docker 模式下以 docker-compose.yml 的 environment 为准
ASR_MODEL_SIZE=small
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_USE_BATCHED=false
ASR_BATCH_SIZE=1
ASR_CHUNK_LENGTH_SECONDS=30
ASR_BEAM_SIZE=5
ASR_BEST_OF=5
ASR_CONDITION_ON_PREVIOUS_TEXT=true
# ASR 引导词：简体中文金融词汇，可提升术语准确率并抑制繁体输出；留空使用内置默认值
ASR_INITIAL_PROMPT=
FFMPEG_BIN=ffmpeg
YT_DLP_BIN=yt-dlp
TESSERACT_BIN=tesseract
VIDEO_OCR_BACKEND=paddleocr
VIDEO_OCR_LANGUAGE=chi_sim+eng
VIDEO_OCR_PADDLE_LANG=ch
VIDEO_OCR_DEVICE=auto
VIDEO_OCR_SCORE_THRESH=0.75
VIDEO_OCR_DET_MODEL_NAME=PP-OCRv5_server_det
VIDEO_OCR_REC_MODEL_NAME=PP-OCRv5_server_rec
VIDEO_FRAME_INTERVAL_SECONDS=15
VIDEO_MAX_FRAMES=18
VIDEO_VISUAL_CUE_WINDOW_SECONDS=3
VIDEO_VISUAL_TRANSCRIPT_WINDOW_SECONDS=12
VIDEO_VISUAL_MAX_CONTEXT_ITEMS=10
VIDEO_VISION_MAX_FRAMES=12
VIDEO_VISION_TEXT_FALLBACK=1
# 单个视频最多用 LLM 做事件抽取的分块数（0 表示不限制），超出部分回退为规则抽取
VIDEO_EVENT_LLM_MAX_CHUNKS=40
PYANNOTE_TOKEN=
CONTENT_MAX_AUDIO_MINUTES=180
